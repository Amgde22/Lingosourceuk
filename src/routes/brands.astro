---
// routes/brands.astro
import { getLocalePath, t } from "i18n:astro";
import {getOptimizedImage} from "@utils/utils"
import BaseLayout from "@layouts/BaseLayout.astro";
import mobileLandingImage from "@assets/images/hero.png" // <-- THE PATH TO THE ASSET YOU WANT TO PRELOAD - The asset must live in src
// Optimize our landing image and pass it as props to the BaseLayout (for preloading) and Hero (for rendering)


const brandDisclosure = t("legal:brandDisclosure", { returnObjects: true });
const optimizedMobileLandingImage = await getOptimizedImage(mobileLandingImage)
---

<BaseLayout
title={"brands"}
description={t("home:about.layout.description")}
preloadedImage = {optimizedMobileLandingImage}
>
    <main class="wrap">

      <!-- hero -->
      <header class="hero">
        <div class="eyebrow">Brand Disclosure</div>
        <h1>{brandDisclosure.hero.title}</h1>
        <p class="subtitle">{brandDisclosure.hero.subtitle}</p>
      </header>

      <hr />

      <!-- intro -->
      <section class="text-block">
        <p>{brandDisclosure.introduction.paragraph1}</p>
        <p>{brandDisclosure.introduction.paragraph2}</p>
      </section>

      <!-- relationship -->
      <section class="relationship">
        <h2>{brandDisclosure.brandRelationship.title}</h2>
        <p>{brandDisclosure.brandRelationship.description}</p>
      </section>

      <!-- company / brand grid -->
      <section class="grid">
        <div class="card">
          <h3>{brandDisclosure.companyDetails.legalEntityLabel}</h3>
          <p>{brandDisclosure.companyDetails.legalEntity}</p>

          <div class="meta">
            <span>{brandDisclosure.companyDetails.registeredCountryLabel}</span>
            <strong>{brandDisclosure.companyDetails.registeredCountry}</strong>
          </div>

          <a href={brandDisclosure.companyDetails.companyWebsite} class="link">
            {brandDisclosure.companyDetails.companyWebsite}
          </a>
        </div>

        <div class="card brand">
          <h3>{brandDisclosure.companyDetails.brandLabel}</h3>
          <p>{brandDisclosure.companyDetails.brandName}</p>

          <a href={brandDisclosure.companyDetails.brandWebsite} class="link">
            {brandDisclosure.companyDetails.brandWebsite}
          </a>
        </div>
      </section>

      <!-- sms -->
      <section class="sms">
        <h2>{brandDisclosure.smsCompliance.title}</h2>
        <p>{brandDisclosure.smsCompliance.paragraph1}</p>
        <p>{brandDisclosure.smsCompliance.paragraph2}</p>
        <p class="note">{brandDisclosure.smsCompliance.paragraph3}</p>
      </section>

      <!-- contact -->
      <section class="contact">
        <h2>{brandDisclosure.contact.title}</h2>
        <p>{brandDisclosure.contact.paragraph}</p>
      </section>

    </main>
</BaseLayout>

    <style lang="less">
      .wrap{
        max-width: 820px;
        margin:auto;
        padding:var(--sectionPadding);
        color:var(--bodyTextColor);
      }

      .hero{
        margin-bottom:var(--spacing-xl);
      }

      .hero h1{
        font-size:clamp(2.2rem,5vw,3rem);
        line-height:1.1;
        letter-spacing:-0.02em;
        margin:0;
      }

      .subtitle{
        color:var(--gray-600);
        margin-top:var(--spacing-sm);
      }

      .eyebrow{
        font-size:0.75rem;
        letter-spacing:.15em;
        text-transform:uppercase;
        color:var(--primary-400);
        margin-bottom:var(--spacing-sm);
      }

      hr{
        border:none;
        border-top:1px solid var(--gray-200);
        margin:var(--spacing-xl) 0;
      }

      section{
        margin-bottom:var(--spacing-xl);
      }

      h2{
        font-size:1.2rem;
        margin-bottom:var(--spacing-sm);
        letter-spacing:-0.01em;
      }

      p{
        line-height:1.6;
        color:var(--gray-700);
      }

      .grid{
        display:grid;
        gap:var(--spacing-lg);
        grid-template-columns:repeat(auto-fit,minmax(240px,1fr));
      }

      .card{
        padding:var(--spacing-lg);
        border:1px solid var(--gray-200);
        border-radius:8px;
      }

      .brand{
        border-color:var(--primary-200);
      }

      .meta{
        margin:var(--spacing-sm) 0;
        font-size:0.85rem;
        color:var(--gray-500);
        display:flex;
        flex-direction:column;
      }

      .link{
        font-size:0.9rem;
        color:var(--primary);
        text-decoration:none;
      }

      .link:hover{
        text-decoration:underline;
      }

      .note{
        font-size:0.9rem;
        color:var(--gray-500);
      }

      .contact{
        padding-top:var(--spacing-lg);
        border-top:1px solid var(--gray-200);
      }
    </style>
